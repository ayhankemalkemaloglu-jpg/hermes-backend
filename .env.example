PORT=4000
NODE_ENV=production
AUTH_TOKEN=change-me-with-openssl-rand-hex-32
WEBHOOK_SECRET=change-me-with-openssl-rand-hex-32
DB_PATH=/var/lib/hermes/hermes.db
LOG_PATH=/var/log/hermes/app.log
CORS_ORIGINS=http://localhost:3000,https://hrms.gelecekbul.com
BINANCE_API_BASE=https://api.binance.com
# Binance WebSocket base for live crypto prices (@miniTicker, ~1s per symbol)
BINANCE_WS_BASE=wss://stream.binance.com:9443/ws
# Yahoo Finance base for BIST (Borsa İstanbul) equity prices/charts (<TICKER>.IS)
YAHOO_API_BASE=https://query1.finance.yahoo.com
# Optional explicit BIST ticker allowlist (comma-separated), e.g. THYAO,GARAN,ASELS.
# Bare tickers are treated as BIST even when empty; this only overrides edge cases.
BIST_SYMBOLS=
# BIST (Yahoo) poll cadence (ms). Keep at a few seconds — per-second gets rate-limited.
BIST_POLL_INTERVAL_MS=5000
# Cadence (ms) for broadcasting the unified live snapshot to dashboards
LIVE_BROADCAST_INTERVAL_MS=1000

# --- Agent control (VPS Agent tab) ---
# Trading bot command webhook + bearer (uniswap-v3-monitor). Unset = commands
# return "not_configured" (status/logs still work).
BOT_COMMAND_URL=http://localhost:3000/webhook/command
BOT_AUTH_TOKEN=
# pm2 process names the dashboard may inspect/manage (comma-separated). Empty = all.
AGENT_PM2_NAMES=quant-bot,uniswap-bot,sepolia-receiver,hourly-reporter,hermes-backend,hermes-frontend
BOT_COMMAND_TIMEOUT_MS=5000

# --- Assistant (Hermes chat / voice agent) ---
# LLM that powers the "Hermes ile Konuşma" tab + voice agent. Key stays here only.
ASSISTANT_PROVIDER=minimax
ASSISTANT_API_KEY=
ASSISTANT_MODEL=MiniMax-Text-01
# MiniMax intl: https://api.minimax.io  |  OpenAI: https://api.openai.com
ASSISTANT_API_BASE=https://api.minimax.io
ASSISTANT_TIMEOUT_MS=30000
# Purge briefings older than this many days
BRIEFING_RETENTION_DAYS=30
# How often the cleanup job runs (ms)
CLEANUP_INTERVAL_MS=3600000

# --- Portfolio risk guard (FINDING 3) ---
# Record-and-flag mode: never drops a mirrored trade, only emits RISK_BREACH.
# Set to false to disable the guard entirely.
RISK_ENABLED=true
# Stop admitting once realized P&L for the UTC day <= -this (USD)
RISK_DAILY_LOSS_LIMIT=500
# Max total notional across the whole book (USD)
RISK_TOTAL_CAP=10000
# Max notional in a single symbol (USD)
RISK_SYMBOL_CAP=3000
# Max notional within a correlation group (USD; default group = all crypto)
RISK_CORRELATED_CAP=8000
# Duplicate if same symbol+side is open within this fraction of price (0.0015 = 0.15%)
RISK_DUPLICATE_PRICE_PCT=0.0015
# Briefings carry no size, so each position counts as this fixed notional (USD)
RISK_DEFAULT_NOTIONAL=1000
