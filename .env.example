PORT=4000
NODE_ENV=production
AUTH_TOKEN=change-me-with-openssl-rand-hex-32
WEBHOOK_SECRET=change-me-with-openssl-rand-hex-32
DB_PATH=/var/lib/hermes/hermes.db
LOG_PATH=/var/log/hermes/app.log
CORS_ORIGINS=http://localhost:3000,https://hrms.gelecekbul.com
BINANCE_API_BASE=https://api.binance.com
# Live price/P&L poller cadence (ms) for open positions → price:update / pnl:update
PRICE_POLL_INTERVAL_MS=30000
# Purge briefings older than this many days
BRIEFING_RETENTION_DAYS=30
# How often the cleanup job runs (ms)
CLEANUP_INTERVAL_MS=3600000
